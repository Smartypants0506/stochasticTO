# syntax=docker/dockerfile:1
FROM benpachev/cudolfinx:v0.9.0-cuda12.6

LABEL description="Robust Topo-Opt — Alienware m13 RTX 3060 Ti"

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PETSC_OPTIONS="-vec_type cuda -mat_type aijcusparse" \
    CUDA_VISIBLE_DEVICES=0 \
    PYVISTA_OFF_SCREEN=false \
    OMP_NUM_THREADS=4 \
    MKL_NUM_THREADS=4

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget vim htop tmux sudo \
    libglu1-mesa libgl1 libglx-mesa0 libxrender1 xvfb \
    openmpi-bin libopenmpi-dev \
    libhdf5-dev libnetcdf-dev libmetis-dev \
    cmake ninja-build build-essential gfortran pkg-config \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

ARG USERNAME=devuser
ARG USER_UID=1001
ARG USER_GID=1001

RUN groupadd --gid ${USER_GID} ${USERNAME} \
    && useradd --uid ${USER_UID} --gid ${USER_GID} -m -s /bin/bash ${USERNAME} \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

WORKDIR /workspace
RUN chown ${USERNAME}:${USERNAME} /workspace

USER ${USERNAME}
ENV PATH="/home/${USERNAME}/.local/bin:${PATH}"

COPY --chown=${USERNAME}:${USERNAME} requirements.txt .
USER root
RUN python -m pip install --upgrade pip setuptools wheel
RUN pip install --upgrade pip setuptools wheel \
    && pip install -r requirements.txt \
    && pip install gmsh openturns \
    && pip install cupy-cuda12x \
    && pip install nvidia-ml-py pynvml

RUN git clone https://github.com/mdolab/pyoptsparse.git /tmp/pyoptsparse \
    && cd /tmp/pyoptsparse \
    && pip install .

CMD ["bash"]